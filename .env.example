# ============================================================================
#  Bagre — exemplo de configuração
# ============================================================================
#
# Copie pra .env e preencha. NENHUM valor abaixo deve ser usado em produção
# como está — todos os campos com placeholder precisam ser substituídos por
# valores únicos do seu ambiente. A API recusa boot se JWT_SECRET estiver
# com valor de exemplo, vazio ou abaixo de 32 chars (fail-closed).

# ----------------------------------------------------------------------------
# OBRIGATÓRIO
# ----------------------------------------------------------------------------

# JWT_SECRET — assina os tokens de sessão. PRECISA ser único e ≥32 chars.
# Gere com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=

# ----------------------------------------------------------------------------
# RECOMENDADO
# ----------------------------------------------------------------------------

# Email do primeiro usuário admin criado no boot.
BOOTSTRAP_ADMIN_EMAIL=admin@bagre.local

# Senha do primeiro admin. Se VAZIA, será gerada aleatoriamente e impressa
# uma única vez no log do container API no primeiro boot. mustChangePwd=true
# força troca no primeiro login. Para definir manualmente, ≥10 chars.
BOOTSTRAP_ADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# OPCIONAIS (recursos opt-in)
# ----------------------------------------------------------------------------

# ADMIN_TOKEN — token estático usado por endpoints administrativos antigos.
# Deixa vazio se não usar. Quando definir, use 32+ chars aleatórios.
ADMIN_TOKEN=

# INGEST_TOKEN — autentica POST /api/ingest/* (scanners externos, scripts).
# Deixa vazio pra desligar o ingest. Quando definir, use 32+ chars aleatórios.
# Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
INGEST_TOKEN=

# CLOUD_CREDS_KEY — chave AES-256-GCM que cifra credenciais de CloudAccount
# no banco. Obrigatória se você for usar /admin/cloud-accounts (sync AWS/Azure/GCP).
# Gere com:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 chars hex. Perder/trocar essa chave INVALIDA todas as credenciais
# já guardadas — reconecte os accounts depois.
CLOUD_CREDS_KEY=

# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY — só preencha se for usar o modo
# ASSUME_ROLE no CloudAccount AWS (Bagre usa essas creds base pra fazer
# STS:AssumeRole na conta destino). Modo ACCESS_KEY guarda as creds por
# account criptografadas e ignora estas vars.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
